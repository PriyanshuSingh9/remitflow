generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

enum TransactionStatus {
  pending
  escrow_locked
  offramp_pending
  offramp_ready
  escrow_released
  completed
  failed
  refunded
}

model User {
  id                      String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  googleSubject           String?       @unique @map("firebase_uid") @db.Text
  email                   String        @unique @db.Text
  displayName             String?       @map("display_name") @db.Text
  photoUrl                String?       @map("photo_url") @db.Text
  phoneNumber             String?       @map("phone_number") @db.Text
  walletAddress           String        @unique @map("wallet_address") @db.Text
  country                 String        @default("US") @db.Text
  bankDetails             String?       @map("bank_details") @db.Text
  availableBalanceUsd     Decimal       @default(0) @map("available_balance_usd") @db.Decimal(12, 2)
  lifetimeSavingsUsd      Decimal       @default(0) @map("lifetime_savings_usd") @db.Decimal(12, 2)
  createdAt               DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  sentTransactions        Transaction[] @relation("sender")
  receivedTransactions    Transaction[] @relation("receiver")

  @@map("users")
}

model ExchangeRate {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  baseCurrency      String   @map("base_currency") @db.VarChar(3)
  quoteCurrency     String   @map("quote_currency") @db.VarChar(3)
  rate              Decimal  @db.Decimal(12, 4)
  cheaperPercentage Decimal  @map("cheaper_percentage") @db.Decimal(5, 2)
  asOf              DateTime @map("as_of") @db.Timestamptz(6)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([baseCurrency, quoteCurrency])
  @@map("exchange_rates")
}

model Transaction {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  senderId        String            @map("sender_id") @db.Uuid
  receiverId      String            @map("receiver_id") @db.Uuid
  sender          User              @relation("sender", fields: [senderId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  receiver        User              @relation("receiver", fields: [receiverId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  amountUsd       Decimal           @map("amount_usd") @db.Decimal(12, 2)
  amountUsdc      Decimal           @map("amount_usdc") @db.Decimal(18, 8)
  amountInr       Decimal           @map("amount_inr") @db.Decimal(12, 2)
  feeUsd          Decimal           @map("fee_usd") @db.Decimal(8, 2)
  txHash          String?           @unique @map("tx_hash") @db.Text
  status          TransactionStatus @default(pending)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt     DateTime?         @map("completed_at") @db.Timestamptz(6)

  // ─── Escrow & Rate Lock fields (Phase 1) ──────────────────────────
  lockedUsdToUsdc Decimal?          @map("locked_usd_to_usdc") @db.Decimal(18, 8)
  lockedUsdcToInr Decimal?          @map("locked_usdc_to_inr") @db.Decimal(12, 4)
  escrowId        Int?              @map("escrow_id")
  escrowState     String?           @map("escrow_state") @db.VarChar(20)
  escrowTxHash    String?           @unique @map("escrow_tx_hash") @db.Text
  releaseTxHash   String?           @unique @map("release_tx_hash") @db.Text
  rampOrders      RampOrder[]

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@index([createdAt])
  @@map("transactions")
}

model RampOrder {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type            String      @db.VarChar(10) // "onramp" | "offramp"
  transactionId   String      @map("transaction_id") @db.Uuid
  transaction     Transaction @relation(fields: [transactionId], references: [id])
  externalOrderId String?     @unique @map("external_order_id") @db.Text
  status          String      @default("CREATED") @db.VarChar(30)
  fiatCurrency    String      @map("fiat_currency") @db.VarChar(3)
  fiatAmount      Decimal     @map("fiat_amount") @db.Decimal(12, 2)
  cryptoCurrency  String      @default("USDC") @map("crypto_currency") @db.VarChar(10)
  cryptoAmount    Decimal     @map("crypto_amount") @db.Decimal(18, 8)
  walletAddress   String      @map("wallet_address") @db.Text
  bankDetails     String?     @map("bank_details") @db.Text
  txHash          String?     @map("tx_hash") @db.Text
  metadata        String?     @db.Text
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([transactionId])
  @@index([type, status])
  @@map("ramp_orders")
}
